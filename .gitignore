content-full/
content-private/
*.full.md
*.private.md
*-full.*
*-private.*

# Content source files (full versions)
content/**/*.full.md
content/**/*-full.md
content/**/*-private.md

# Security keys and credentials
.env
.env.*
!.env.example
*.key
*.pem
*.p12
auth-config.*
secrets.*

